{
  "mode": "ltx_cloud",
  "ltx_repo_path": "/absolute/path/to/LTX-Video",
  "ltx_python": "/absolute/path/to/ltx-hdr-resolve/.cloud-venv/bin/python",
  "ltx_hdr_script": "packages/ltx-pipelines/src/ltx_pipelines/hdr_ic_lora.py",
  "cloud_api_key_path": "/absolute/path/to/.ltx-hdr-resolve/secrets.json",
  "cloud_upload_limit_mb": 100,
  "cloud_poll_seconds": 5,
  "cloud_timeout_seconds": 1800,
  "output_root": "/absolute/path/to/LTX_HDR_Output",
  "distilled_checkpoint": "/absolute/path/to/models/ltx-2.3-22b-distilled-1.1.safetensors",
  "upscaler": "/absolute/path/to/models/ltx-2.3-spatial-upscaler-x2-1.1.safetensors",
  "lora": "/absolute/path/to/models/ltx-2.3-22b-ic-lora-hdr-0.9.safetensors",
  "text_embeddings": "/absolute/path/to/models/ltx-2.3-22b-ic-lora-hdr-scene-emb.safetensors",
  "exr_half": true,
  "high_quality": false,
  "skip_mp4": true,
  "no_save_exr": false,
  "seed": 10,
  "max_frames": 49,
  "spatial_tile": 768,
  "offload": "cpu",
  "extra_env": {}
}
